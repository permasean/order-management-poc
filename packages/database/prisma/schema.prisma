generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DispatchType {
  NEW_INSTALL
  REPAIR
  SITE_SURVEY
}

enum OrderStatus {
  PENDING_APPROVAL
  REQUEST_SENT
  CONFIRMED
  COMPLETED
  CANCELED
  FAILED
}

model Order {
  id                String       @id @default(uuid())
  ticketId          String
  siteAddress       String
  scheduledDateTime DateTime
  dispatchType      DispatchType
  vendorName        String?
  vendorOrderNumber String?
  techFirstName     String?
  techLastName      String?
  techMobilePhone   String?
  status            OrderStatus  @default(PENDING_APPROVAL)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("orders")
}
